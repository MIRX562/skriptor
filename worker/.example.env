# Redis connection string
# Format: redis://[:password@]host[:port][/db]
REDIS_URL=redis://:your_password@localhost:6379

# Backend callback configuration
BACKEND_CALLBACK_URL=http://localhost:3000/api/transcribe-upload/worker-callback

# Shared secret for HMAC signing (must match the server's WORKER_SHARED_SECRET)
WORKER_SHARED_SECRET=your_shared_secret

# Hugging Face token for speaker diarization
HUGGING_FACE_TOKEN=your_hugging_face_token

# Device to use for inference (cuda or cpu)
DEVICE=cuda
