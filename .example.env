# Postgresql database url
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# S3 Compatible Storage (Garage/MinIO)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET=your_bucket
S3_REGION=us-east-1



# Redis
# Format: redis://[:password@]host[:port][/db]
REDIS_URL=redis://:your_password@localhost:6379

# Auth
BETTER_AUTH_SECRET=your_secret
BETTER_AUTH_URL=your_app_base_url

# Social auth 
GOOGLE_CLIENT_ID=your_gc_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Resend
RESEND_API_KEY=your_resend_api_key

# Hugging face
HUGGING_FACE_TOKEN=your_HF_token

# worker secret
WORKER_SHARED_SECRET=your_shared_secret

# Worker configuration (Python worker)
BACKEND_CALLBACK_URL=http://localhost:3000/api/transcribe-upload/worker-callback
DEVICE=cuda # Options: cuda, cpu